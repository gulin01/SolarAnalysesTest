# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_public_token_here
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000
FASTAPI_INTERNAL_URL=http://backend:8000

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# ── Backend (FastAPI) ─────────────────────────────────────────────────────────
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

DATABASE_URL=postgresql+asyncpg://solarsight:solarsight@postgres:5432/solarsight
REDIS_URL=redis://redis:6379/0

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=solarsight
MINIO_SECURE=false

CORS_ORIGINS=http://localhost:3000,http://localhost

# Local storage: public API URL for model download links (e.g. http://localhost:8000)
# PUBLIC_API_URL=http://localhost:8000

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1